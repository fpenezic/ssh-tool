# Claude harness
.claude/
CLAUDE.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
# Windows / WSL NTFS "Mark of the Web" sidecar streams that leak in when
# files are copied from /mnt/c.
*:Zone.Identifier
**/*:Zone.Identifier

# Env / local
.env
.env.local
.env.*.local
*.local

# Logs
*.log
logs/

# App-generated (dev)
*.db
*.db-journal
*.db-shm
*.db-wal

# SSH keys that might leak into the workspace if a subprocess CWD isn't ~
**/id_rsa
**/id_rsa.pub
**/id_ecdsa
**/id_ecdsa.pub
**/id_ecdsa-cert.pub
**/id_ed25519
**/id_ed25519.pub
**/id_*-cert.pub

# Wails autogenerated bindings - regenerated on every build, but we
# commit them so frontend builds without first running `wails build`.
# Comment out the next line if you prefer to regenerate locally each time.
# frontend/wailsjs/

# v3 build output
/bin/


# task cache
/.task/
wails_windows_amd64.syso
/build/windows/info.generated.json

# Android build artifacts (generated by wails3 task android:*)
/build/android/.gradle/
/build/android/build/
/build/android/app/build/
/build/android/app/src/main/jniLibs/

# Generated from ssh-tool.desktop.in by generate:dotdesktop; edit the .in
build/linux/ssh-tool.desktop

# Local sidecar helper build outputs (CI builds + publishes these)
netbird-helper/netbird-helper
netbird-helper/ssh-tool-netbird-*
tailscale-helper/tailscale-helper
tailscale-helper/ssh-tool-tailscale-*

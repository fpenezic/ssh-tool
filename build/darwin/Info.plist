<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>ssh-tool</string>
    <key>CFBundleIdentifier</key>
    <string>com.filippenezic.ssh-tool</string>
    <key>CFBundleName</key>
    <string>ssh-tool</string>
    <key>CFBundleDisplayName</key>
    <string>ssh-tool</string>
    <key>CFBundleVersion</key>
    <string>0.1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleIconFile</key>
    <string>icons</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- ssh-tool:// deep links (catalog "Open in ssh-tool" buttons).
         Launch Services reads this when it indexes the bundle; the
         in-app Register button just forces a re-index via lsregister. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.filippenezic.ssh-tool.deeplink</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>ssh-tool</string>
            </array>
        </dict>
    </array>
    <key>NSHumanReadableCopyright</key>
    <string>(c) 2026, Filip Penezic</string>
    <!-- Allow outbound connections to SSH servers and localhost forwards -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>

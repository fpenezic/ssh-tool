<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="ssh-tool"
        Arguments=""
        InstallLocation="C:\Program Files\Filip Penezic\ssh-tool">
    </Installer>
    <PackageInformation
        PackageName="ssh-tool"
        PackageDisplayName="ssh-tool"
        PublisherName="CN=Filip Penezic"
        PublisherDisplayName="Filip Penezic"
        Version="0.1.0.0"
        PackageDescription="Cross-platform SSH connection manager">
        <Capabilities>
            <Capability Name="runFullTrust" />

        </Capabilities>
        <Applications>
            <Application
                Id="com.filippenezic.ssh-tool"
                Description="Cross-platform SSH connection manager"
                DisplayName="ssh-tool"
                ExecutableName="ssh-tool"
                EntryPoint="Windows.FullTrustApplication">

            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>ssh-tool</DisplayName>
            <PublisherDisplayName>Filip Penezic</PublisherDisplayName>
            <Description>Cross-platform SSH connection manager</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="ssh-tool.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>

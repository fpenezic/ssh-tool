# The @xterm/addon-canvas (and addon-webgl) packages still declare a peer
# dependency on @xterm/xterm ^5, but run fine against the xterm 6 beta we
# pin - the same situation the project already relied on for the webgl
# addon. Accept the mismatch so `npm ci` (CI) and `npm install` (local)
# resolve without --legacy-peer-deps on every invocation.
legacy-peer-deps=true
